server {
    listen 80;
    server_name nishimuraya-soga.com www.nishimuraya-soga.com;

    server_tokens off;
    client_max_body_size 10m;

    location /static/ {
        alias /srv/nishimuraya/app/staticfiles/;
        access_log off;
        expires 7d;
    }

    location /media/ {
        alias /srv/nishimuraya/app/media/;
        access_log off;
        expires 7d;
        add_header X-Content-Type-Options nosniff always;
    }

    location / {
        proxy_pass http://unix:/run/nishimuraya/gunicorn.sock;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
